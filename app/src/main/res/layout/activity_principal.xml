<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_login"
    android:padding="24dp"
    tools:context=".principalActivity">

    <LinearLayout
        android:layout_width="325dp"
        android:layout_height="701dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="5dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.145">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:fontFamily="sans-serif-black"
            android:foregroundTint="@color/white"
            android:rotationX="6"
            android:text="Registro"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            android:textColor="@color/white" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txtCedula"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Cedula"
            app:boxBackgroundColor="#33FFFFFF"
            app:boxStrokeColor="#e94560"
            app:errorTextColor="#FF6B6B"
            app:hintTextColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCedula"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:imeOptions="actionNext"
                android:inputType="phone"
                android:textColor="#FFFFFF"
                android:textColorHint="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txtNombres"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:hint="Nombres"
            app:boxBackgroundColor="#33FFFFFF"
            app:boxStrokeColor="#e94560"
            app:errorTextColor="#FF6B6B"
            app:hintTextColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNombres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:textColor="#FFFFFF" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txtApellidos"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:hint="Apellidos"
            app:boxBackgroundColor="#33FFFFFF"
            app:boxStrokeColor="#e94560"
            app:errorTextColor="#FF6B6B"
            app:hintTextColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etApellidos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_weight="1"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:textColor="#FFFFFF" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="17dp"
            android:layout_marginTop="5dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView5"
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="15dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-black"
                android:text="Nacionalidad"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/textView6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Genero"
                android:textColor="@color/white"
                tools:fontFamily="sans-serif-black" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="1dp"
            android:foregroundTint="@color/white"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/cbNacionalidad"
                android:layout_width="140dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:background="@drawable/bg_borde_spinner"
                android:spinnerMode="dropdown"
                android:theme="@style/ThemeOverlay.AppCompat.Dark"
                tools:foregroundTint="@color/white" />

            <Spinner
                android:id="@+id/cbGenero"
                android:layout_width="167dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:background="@drawable/bg_borde_spinner"
                android:foregroundTint="@color/white"
                android:spinnerMode="dropdown"
                android:theme="@style/ThemeOverlay.AppCompat.Dark" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/txtEdad"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="77dp"
                android:layout_height="match_parent"
                android:layout_marginRight="5dp"
                android:hint="Edad"
                app:boxBackgroundColor="#33FFFFFF"
                app:boxStrokeColor="#e94560"
                app:errorTextColor="#FF6B6B"
                app:hintTextColor="#FFFFFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEdad"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:editable="true"
                    android:imeOptions="actionNext"
                    android:inputType="number|numberDecimal"
                    android:textColor="#FFFFFF"
                    android:textColorHint="@color/white" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/txtFecha"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="193dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Fecha de Nacimiento"
                app:boxBackgroundColor="#33FFFFFF"
                app:boxStrokeColor="#e94560"
                app:errorTextColor="#FF6B6B"
                app:hintTextColor="#FFFFFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFecha"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginRight="5dp"
                    android:editable="false"
                    android:foregroundTint="@color/white"
                    android:imeOptions="actionNext"
                    android:inputType="datetime|date"
                    android:textColor="#FFFFFF"
                    android:textColorHint="@color/white" />

            </com.google.android.material.textfield.TextInputLayout>

            <ImageButton
                android:id="@+id/btnCalendar"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:onClick="showDatePickerDialog"
                app:srcCompat="@android:drawable/ic_menu_my_calendar" />

        </LinearLayout>

        <TextView
            android:id="@+id/textView3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="sans-serif-black"
            android:foregroundTint="@color/white"
            android:text="Estado Civil"
            android:textColor="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/btnSoltero"
                android:layout_width="105dp"
                android:layout_height="match_parent"
                android:layout_marginRight="10dp"
                android:buttonTint="@color/white"
                android:foregroundTint="@color/white"
                android:onClick="onRadioButtonClicked"
                android:text="Soltero/a"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <RadioButton
                android:id="@+id/btnCasado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:buttonTint="@color/white"
                android:foregroundTint="@color/white"
                android:onClick="onRadioButtonClicked"
                android:text="Casado/a"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <RadioButton
                android:id="@+id/btnDivorciado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/white"
                android:foregroundTint="@color/white"
                android:onClick="onRadioButtonClicked"
                android:text="Divorciado/a"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/textView4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:fontFamily="sans-serif-black"
            android:foregroundTint="@color/white"
            android:text="Nivel de Inglés"
            android:textColor="@color/white" />

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_gravity="center"
            android:backgroundTint="@color/white"
            android:foregroundTint="@color/white"
            android:numStars="5"
            android:progressTint="#FFC107" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:gravity="bottom|center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRegistrar"
                android:layout_width="139dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="1dp"
                android:backgroundTint="#8BC34A"
                android:onClick="registrar"
                android:text="Registrarse" />

            <Button
                android:id="@+id/btnBorrar"
                android:layout_width="132dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="15dp"
                android:onClick="borrar"
                android:text="Borrar" />
        </LinearLayout>

        <Button
            android:id="@+id/btnRegresar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="70dp"
            android:layout_marginRight="70dp"
            android:backgroundTint="#03A9F4"
            android:onClick="regresar"
            android:text="Regresar" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>