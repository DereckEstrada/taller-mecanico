<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5"
    android:padding="12dp">

    <!-- Fila: filtro estado + botón nuevo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Spinner
            android:id="@+id/spinnerFiltroEstado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:drawable/btn_dropdown"
            android:padding="8dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnNuevaReparacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Nueva"
            android:backgroundTint="#e94560"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No hay reparaciones registradas."
        android:textColor="#9E9E9E"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listViewReparaciones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp" />

</LinearLayout>
