<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5"
    android:padding="12dp">

    <!-- ── Fila de búsqueda ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/etBuscar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Buscar por nombre o cédula..."
            android:inputType="text"
            android:background="@android:drawable/edit_text"
            android:padding="8dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnBuscar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buscar"
            android:backgroundTint="#1a3a6e"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- ── Botón Nuevo Cliente ──────────────────────────────────────────── -->
    <Button
        android:id="@+id/btnNuevoCliente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ Nuevo Cliente"
        android:backgroundTint="#e94560"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp" />

    <!-- ── Mensaje cuando no hay datos ─────────────────────────────────── -->
    <TextView
        android:id="@+id/tvVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No hay clientes registrados."
        android:textColor="#9E9E9E"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone" />

    <!-- ── Lista de clientes ────────────────────────────────────────────── -->
    <ListView
        android:id="@+id/listViewClientes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp" />

</LinearLayout>