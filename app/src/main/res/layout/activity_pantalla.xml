<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/fondo_login"
    android:padding="24dp"
    android:gravity="center_horizontal"
    tools:context=".PantallaActivity">

    <!-- Cabecera universitaria -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="32dp"
        app:cardBackgroundColor="#1a3a6e"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Universidad de Guayaquil"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Facultad de Ciencias Matemáticas y Físicas"
                android:textColor="#E0E0E0"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingeniería en Sistemas"
                android:textColor="#E0E0E0"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Materia: Desarrollo de Aplicaciones Móviles"
                android:textColor="#B0C4DE"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Integrante 1 | Integrante 2 | Integrante 3"
                android:textColor="#90CAF9"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Ícono de herramienta -->
    <ImageView
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/ic_herramienta"
        android:layout_marginBottom="24dp"
        android:contentDescription="Herramienta" />

    <!-- Título bienvenida -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SISTEMA DE GESTIÓN INTEGRAL\nPARA TALLERES MECÁNICOS"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="18sp"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvBienvenida"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bienvenido"
        android:textColor="#90CAF9"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <!-- Botón Borrar Datos -->
    <Button
        android:id="@+id/btnBorrarDatos"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="BORRAR DATOS DE SESIÓN"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="14sp"
        android:backgroundTint="#e94560"
        app:cornerRadius="28dp" />

</LinearLayout>
